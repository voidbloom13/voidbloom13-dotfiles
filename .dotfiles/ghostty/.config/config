# background-image = "~/voidbloom13-dotfiles/assets/terminal-wallpaper.jpg"
# background-image-fit = "cover"
# maximize = true
background = 000000
foreground = c8c8c8
background-opacity = 0.5
background-blur = true
cursor-style = block
cursor-color = 0088ff
cursor-style-blink = true
shell-integration-features = no-cursor
title = "Ghostty"
theme = "Catppuccin Mocha"
window-padding-x = 0
window-padding-y = 0
window-theme = ghostty
window-titlebar-background = 000067

font-family = "FiraCode Nerd Font"
font-family-bold = "FiraCode Nerd Font"
font-family-italic = "VictorMono Nerd Font"
font-family-bold-italic = "VictorMono Nerd Font"
font-feature = "+calt, +liga, +dlig"
